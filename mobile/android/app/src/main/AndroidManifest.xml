<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- gRPC over TLS to daemons on the LAN. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- mDNS discovery needs Wi-Fi state + a multicast lock. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <!--
        Receiving-role foreground service (T-X36): keeps the inbound
        server + mDNS advertise + heartbeat alive under Doze/OEM kills
        while "receiving" is on. FOREGROUND_SERVICE_CONNECTED_DEVICE
        matches the service's declared foregroundServiceType below
        (required on API 34+); POST_NOTIFICATIONS is needed to actually
        show the mandatory persistent notification on API 33+ (the
        service still runs foregrounded without it, just silently).
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="Connectible"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Notification mirroring (T-B4). Android binds this service itself
            once the user enables "Connectible" under Settings, Notification
            access; we cannot start it. BIND_NOTIFICATION_LISTENER_SERVICE is
            a system permission that only the OS can hold, which is exactly
            the gate we want. Not exported: only the system should bind it.
        -->
        <service
            android:name=".notifications.ConnectibleNotificationListener"
            android:exported="false"
            android:label="Connectible"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!--
            Receiving-role foreground service (T-X36). Not exported:
            only this app starts/stops it (via ReceivingServicePlugin).
        -->
        <service
            android:name=".net.ReceivingForegroundService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!--
            super_clipboard (Phase L, T-L7): required by the package so
            it can hand image clipboard content to other apps via a
            content URI on Android. See its README's "Android support"
            section.
        -->
        <provider
            android:name="com.superlist.super_native_extensions.DataProvider"
            android:authorities="io.connectible.mobile.SuperClipboardDataProvider"
            android:exported="true"
            android:grantUriPermissions="true" >
        </provider>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
</manifest>

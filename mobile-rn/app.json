{
  "expo": {
    "name": "Connectible",
    "slug": "connectible-mobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "connectible",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#08080A"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "android": {
      "package": "com.connectible.mobile",
      "versionCode": 1,
      "allowBackup": false,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#08080A"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_MULTICAST_STATE",
        "CAMERA",
        "FOREGROUND_SERVICE",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#08080A"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Connectible to use the camera to scan a pairing QR code.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}

# Rust
/target
**/target
# Cargo.lock IS committed: this repo ships applications (daemon, desktop
# shell), so a locked, reproducible dependency set is required and CI
# builds with --locked.

# Node / frontend
desktop/node_modules
desktop/dist

# Tauri / generated
desktop/src-tauri/gen

# Flutter generated proto stubs (regenerated via mobile/tool/gen_proto.sh)
mobile/lib/src/generated/*.dart
# Flutter build output + scaffolded platform dirs
mobile/.dart_tool
mobile/build
# Android (Gradle) build output + caches under the kept android/ project
mobile/android/build
mobile/android/app/build
mobile/android/.gradle
mobile/android/local.properties
mobile/ios
mobile/linux
mobile/macos
mobile/windows
mobile/web
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
# T-N1 battery-measurement scratch output (mobile/tool/battery_measure.sh)
mobile/battery-results/

# Luna's private scratch space for one-off reports she asks Claude to
# produce (audits, investigations, ...) -- not project source or docs,
# never published, never committed.
/luna-space/

# Editor / OS
*.swp
.DS_Store
*~
.idea/
.vscode/

# Flutter DevTools local options (editor-generated, machine-specific)
mobile/devtools_options.yaml

# Stray root-level node_modules: there is no root package.json; frontend
# deps live under desktop/. Never commit an accidental root install.
/node_modules

# Claude Code / agent tooling: keep shared config (launch.json) but never
# commit machine-local settings (permission grants), local worktrees, or
# downloaded skill tooling (not project source).
.claude/settings.local.json
.claude/worktrees/
.claude/skills/
.agents/
skills-lock.json

# Frozen reference backups (CLAUDE.md: never touch/commit this). Not
# gitignoring it is what lets a broad `git add -A`/`git add .` sweep an
# 11GB+ directory of old snapshots into a commit by accident -- always
# stage specific files/paths instead, but belt-and-suspenders here too.
/backups/

# Secrets / environment -- never commit. The daemon's runtime TLS certs
# and DB key live under the XDG data dir (outside the repo), but guard
# against an accidental in-repo secret regardless.
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore
id_rsa*
id_ed25519*
id_ecdsa*
*.mobileprovision
google-services.json
GoogleService-Info.plist
secrets.*
credentials.*
credentials/

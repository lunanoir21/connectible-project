# Rust
/target
**/target
# Cargo.lock IS committed: this repo ships applications (daemon, desktop
# shell), so a locked, reproducible dependency set is required and CI
# builds with --locked.

# Node / frontend
desktop/node_modules
desktop/dist

# Tauri / generated
desktop/src-tauri/gen

# Flutter generated proto stubs (regenerated via mobile/tool/gen_proto.sh)
mobile/lib/src/generated/*.dart
# Flutter build output + scaffolded platform dirs
mobile/.dart_tool
mobile/build
# Android (Gradle) build output + caches under the kept android/ project
mobile/android/build
mobile/android/app/build
mobile/android/.gradle
mobile/android/local.properties
mobile/ios
mobile/linux
mobile/macos
mobile/windows
mobile/web
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies

# Editor / OS
*.swp
.DS_Store
*~
.idea/
.vscode/

# Flutter DevTools local options (editor-generated, machine-specific)
mobile/devtools_options.yaml

# Stray root-level node_modules: there is no root package.json; frontend
# deps live under desktop/. Never commit an accidental root install.
/node_modules

# Claude Code / agent tooling: keep shared config (launch.json) but never
# commit machine-local settings (permission grants) or local worktrees.
.claude/settings.local.json
.claude/worktrees/

# Secrets / environment -- never commit. The daemon's runtime TLS certs
# and DB key live under the XDG data dir (outside the repo), but guard
# against an accidental in-repo secret regardless.
.env
.env.*
*.pem
*.key
*.p12
*.keystore
secrets.*
